# ECS task definition / service env reference.
# Put DB_URL in Secrets Manager or SSM Parameter Store for production.
APP_ENV=production
PORT=8080
DB_STARTUP_TIMEOUT=90s

# Import source files and extracted images.
# For production, point this to persistent storage such as an EFS mount.
IMPORT_STORAGE_DIR=/app/data/imports

# RDS PostgreSQL example:
# DB_URL=host=<rds-endpoint> port=5432 user=<user> password=<password> dbname=<db> sslmode=require
DB_URL=

# If frontend and backend containers run in the same ECS task:
BACKEND_UPSTREAM=http://127.0.0.1:8080

# If frontend is a separate ECS service with Cloud Map/service discovery:
# BACKEND_UPSTREAM=http://<backend-service-name>.<namespace>:8080

NGINX_PORT=80
CLIENT_MAX_BODY_SIZE=64m

# Usually not needed if the browser calls the same ALB/domain through /api.
# Set explicit origins only when API and frontend are on different domains.
CORS_ALLOWED_ORIGINS=
