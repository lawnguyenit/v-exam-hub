# Local compose defaults. Do not commit real production secrets.
APP_ENV=local
PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=80

POSTGRES_USER=admin
POSTGRES_PASSWORD=123
POSTGRES_DB=v_exam_hub
DB_URL=host=db user=admin password=123 dbname=v_exam_hub sslmode=disable
DB_STARTUP_TIMEOUT=90s
IMPORT_STORAGE_DIR=data/imports

# Comma-separated origins. For same-origin nginx/ALB routing this can stay empty in production.
CORS_ALLOWED_ORIGINS=*

NGINX_PORT=80
CLIENT_MAX_BODY_SIZE=64m
BACKEND_UPSTREAM=http://backend:8080
